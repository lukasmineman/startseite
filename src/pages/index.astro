<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Lukas Polzer</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=Martian+Mono:wght@300;400&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0e0e0e;
      --fg: #f0ece3;
      --accent: #c9a96e;
      --muted: #4a4a44;
      --line: #2a2a26;
    }

    body {
      background: var(--bg);
      color: var(--fg);
      font-family: 'Cormorant Garamond', serif;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    /* Background grain */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
      background-size: 180px;
      pointer-events: none;
      z-index: 0;
      opacity: 0.6;
    }

    .container {
      position: relative;
      z-index: 1;
      text-align: center;
      padding: 3rem 2rem;
      animation: fadeUp 1.2s cubic-bezier(0.16, 1, 0.3, 1) both;
    }

    .eyebrow {
      font-family: 'Martian Mono', monospace;
      font-size: 0.65rem;
      font-weight: 300;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 1.5rem;
      opacity: 0;
      animation: fadeUp 1s 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    h1 {
      font-size: clamp(3.5rem, 10vw, 7rem);
      font-weight: 300;
      line-height: 1;
      letter-spacing: -0.02em;
      color: var(--fg);
      margin-bottom: 0.15em;
      opacity: 0;
      animation: fadeUp 1s 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    h1 span {
      display: block;
      font-weight: 600;
      font-style: italic;
      color: var(--accent);
    }

    .divider {
      width: 40px;
      height: 1px;
      background: var(--muted);
      margin: 2rem auto;
      opacity: 0;
      animation: scaleIn 0.8s 0.85s ease forwards;
    }

    .linkedin-link {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      font-family: 'Martian Mono', monospace;
      font-size: 0.7rem;
      font-weight: 300;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--fg);
      text-decoration: none;
      border: 1px solid var(--line);
      padding: 0.85rem 1.8rem;
      position: relative;
      overflow: hidden;
      transition: color 0.4s ease, border-color 0.4s ease;
      opacity: 0;
      animation: fadeUp 1s 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    .linkedin-link::before {
      content: '';
      position: absolute;
      inset: 0;
      background: var(--accent);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1);
      z-index: -1;
    }

    .linkedin-link:hover {
      color: var(--bg);
      border-color: var(--accent);
    }

    .linkedin-link:hover::before {
      transform: scaleX(1);
    }

    .linkedin-link svg {
      width: 14px;
      height: 14px;
      flex-shrink: 0;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    @keyframes scaleIn {
      from { opacity: 0; transform: scaleX(0); }
      to   { opacity: 1; transform: scaleX(1); }
    }
  </style>
</head>
<body>
  <div class="container">
    <p class="eyebrow">Connect with me</p>
    <h1>Lukas<span>Polzer</span></h1>
    <div class="divider"></div>
    <a href="https://www.linkedin.com/in/lukas-polzer-235600284/" target="_blank" rel="noopener noreferrer" class="linkedin-link">
      <svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
      </svg>
      View LinkedIn Profile
    </a>
  </div>
</body>
</html>
